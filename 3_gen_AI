<span class="kw">from</span> fastapi <span class="kw">import</span> FastAPI, HTTPException
<span class="kw">from</span> langsmith <span class="kw">import</span> traceable
<span class="kw">import</span> uvicorn

app = <span class="fn">FastAPI</span>(title=<span class="str">"Enterprise AI API"</span>)

<span class="op">@app.post</span>(<span class="str">"/api/v1/chat"</span>)
<span class="op">@traceable</span>  <span class="cm"># LangSmith tracing</span>
<span class="kw">async def</span> <span class="fn">chat</span>(request: ChatRequest):
    <span class="cm"># 1. Input guardrail check</span>
