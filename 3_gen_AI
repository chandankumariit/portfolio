    <div class="flow-arrow">↓</div>
    <div class="flow-box violet"><div class="flow-label">Sampling</div><div class="flow-text">Select next token</div><div class="flow-sub">Greedy / Top-k / Top-p / Temperature</div></div>
  </div>

  <div class="tw" style="margin-top:16px">
    <table>
      <thead><tr><th>Parameter</th><th>What It Controls</th><th>Low Value</th><th>High Value</th><th>Recommended</th></tr></thead>
      <tbody>
        <tr><td class="hl">Temperature</td><td>Randomness of sampling</td><td>Deterministic (0=greedy)</td><td>Random/creative</td><td>0.7 for chat, 0 for code</td></tr>
        <tr><td class="hl">Top-k</td><td>Sample from top K most likely tokens</td><td>k=1 = greedy</td><td>More diverse</td><td>k=40–50</td></tr>
        <tr><td class="hl">Top-p (nucleus)</td><td>Sample from tokens summing to probability p</td><td>Deterministic</td><td>More creative</td><td>p=0.9–0.95</td></tr>
        <tr><td class="hl">Max tokens</td><td>Max output length</td><td>Short responses</td><td>Long responses</td><td>Task-dependent</td></tr>
