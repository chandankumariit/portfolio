<div class="progress-bar" id="prog"></div>
<button class="fab" id="dlBtn" onclick="downloadPDF()">
  <i class="fas fa-file-pdf"></i> Download PDF
</button>

<div class="page" id="content">

<!-- ═══════════════════════ HERO ═══════════════════════════ -->
<section class="hero">
