<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>GenAI Mastery — Complete Engineer's Handbook</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
<style>
:root {
  --bg: #05070F;
  --s1: #0C1020;
  --s2: #111828;
  --s3: #182030;
  --border: #1E2C44;
  --border2: #263856;
  --gold: #F5C842;
  --gold2: #FFD96A;
  --cyan: #00E5FF;
  --cyan2: #80F0FF;
  --violet: #9B6FFF;
  --violet2: #C4A8FF;
  --rose: #FF6B8A;
  --lime: #A3E635;
  --orange: #FB923C;
  --text: #E8EDF5;
  --text2: #8FA3BF;
  --text3: #4A6080;
  --fh: 'Outfit', sans-serif;
  --fb: 'Outfit', sans-serif;
  --fm: 'DM Mono', monospace;
  --fi: 'Instrument Serif', serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--bg);color:var(--text);font-size:14px;line-height:1.75;overflow-x:hidden}

/* === NOISE OVERLAY === */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");opacity:.4;pointer-events:none;z-index:0}

/* === FAB === */
.fab{position:fixed;bottom:28px;right:28px;z-index:9999;display:flex;align-items:center;gap:10px;background:linear-gradient(135deg,var(--gold),var(--orange));color:#05070F;font-weight:800;font-family:var(--fh);padding:14px 26px;border-radius:100px;border:none;cursor:pointer;font-size:14px;box-shadow:0 8px 40px rgba(245,200,66,.4);transition:all .3s;letter-spacing:.3px}
.fab:hover{transform:translateY(-3px);box-shadow:0 16px 50px rgba(245,200,66,.6)}
.fab:disabled{background:#1E2C44;color:#4A6080;box-shadow:none;cursor:not-allowed;transform:none}
.fab i{font-size:15px}

/* === PROGRESS === */
.progress-bar{position:fixed;top:0;left:0;height:2px;z-index:9998;background:linear-gradient(90deg,var(--gold),var(--cyan),var(--violet));width:0%;transition:width .1s}

/* === LAYOUT === */
.page{max-width:1000px;margin:0 auto;padding:0 28px 100px;position:relative;z-index:1}

/* === HERO === */
.hero{padding:80px 0 60px;position:relative;border-bottom:1px solid var(--border);margin-bottom:60px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 20% 50%,rgba(155,111,255,.06),transparent 60%),radial-gradient(ellipse 50% 60% at 80% 30%,rgba(0,229,255,.05),transparent 60%);pointer-events:none}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-family:var(--fm);font-size:11px;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-bottom:20px;border:1px solid rgba(245,200,66,.25);padding:6px 16px;border-radius:4px;background:rgba(245,200,66,.05)}
.hero h1{font-family:var(--fi);font-size:clamp(42px,8vw,82px);font-weight:400;line-height:1.0;margin-bottom:10px;color:#fff;font-style:italic}
.hero h1 span{font-style:normal;font-family:var(--fh);font-weight:900;background:linear-gradient(135deg,var(--gold),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-tagline{font-size:17px;color:var(--text2);max-width:600px;margin:18px 0 36px;line-height:1.8}
.hero-stats{display:flex;gap:32px;flex-wrap:wrap}
.stat{text-align:left}
.stat-num{font-family:var(--fh);font-size:28px;font-weight:900;color:var(--gold)}
.stat-label{font-size:11px;color:var(--text3);font-family:var(--fm);text-transform:uppercase;letter-spacing:1.5px}

/* === PHASE BADGE === */
.phase-divider{display:flex;align-items:center;gap:16px;margin:60px 0 40px}
.phase-num{font-family:var(--fm);font-size:10px;font-weight:500;color:var(--gold);letter-spacing:3px;text-transform:uppercase;background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.2);padding:6px 14px;border-radius:3px;white-space:nowrap}
.phase-line{flex:1;height:1px;background:linear-gradient(90deg,var(--border2),transparent)}
.phase-title{font-family:var(--fh);font-size:clamp(22px,4vw,32px);font-weight:800;color:#fff;margin-bottom:8px}
.phase-desc{font-size:13px;color:var(--text3);font-family:var(--fm)}

/* === SECTION === */
.section{margin-bottom:52px}
.section-head{display:flex;align-items:flex-start;gap:16px;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.sec-icon{width:46px;height:46px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.si-gold{background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.2)}
.si-cyan{background:rgba(0,229,255,.1);border:1px solid rgba(0,229,255,.2)}
.si-violet{background:rgba(155,111,255,.1);border:1px solid rgba(155,111,255,.2)}
.si-rose{background:rgba(255,107,138,.1);border:1px solid rgba(255,107,138,.2)}
.si-lime{background:rgba(163,230,53,.1);border:1px solid rgba(163,230,53,.2)}
.si-orange{background:rgba(251,146,60,.1);border:1px solid rgba(251,146,60,.2)}
.sec-meta{flex:1}
.sec-tag{font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:2px;margin-bottom:5px}
.sec-title{font-family:var(--fh);font-size:clamp(18px,3vw,24px);font-weight:800;color:#fff}

/* === CARDS === */
.card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:22px;margin-bottom:14px}
.card-gold{border-left:3px solid var(--gold)}
.card-cyan{border-left:3px solid var(--cyan)}
.card-violet{border-left:3px solid var(--violet)}
.card-rose{border-left:3px solid var(--rose)}
.card-lime{border-left:3px solid var(--lime)}
.card-orange{border-left:3px solid var(--orange)}
.card-title{font-family:var(--fm);font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:2px;margin-bottom:10px}
.ct-gold{color:var(--gold)}.ct-cyan{color:var(--cyan)}.ct-violet{color:var(--violet)}
.ct-rose{color:var(--rose)}.ct-lime{color:var(--lime)}.ct-orange{color:var(--orange)}
.card p{color:var(--text2);font-size:13.5px;line-height:1.75;margin-bottom:7px}
.card p:last-child{margin-bottom:0}

/* === GRIDS === */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
@media(max-width:680px){.g2,.g3,.g4{grid-template-columns:1fr}}

/* === FLOW DIAGRAM === */
.flow{display:flex;flex-direction:column;align-items:center;gap:0;margin:20px 0;padding:24px;background:var(--s1);border:1px solid var(--border);border-radius:12px}
.flow-box{background:var(--s2);border:1px solid var(--border2);border-radius:8px;padding:10px 22px;text-align:center;min-width:200px;position:relative}
.flow-box.active{border-color:var(--gold);background:rgba(245,200,66,.06)}
.flow-box.highlight{border-color:var(--cyan);background:rgba(0,229,255,.06)}
.flow-box.violet{border-color:var(--violet);background:rgba(155,111,255,.06)}
.flow-label{font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:3px}
.flow-text{font-size:13px;font-weight:700;color:#fff}
.flow-sub{font-size:11px;color:var(--text3);font-family:var(--fm);margin-top:2px}
.flow-arrow{color:var(--gold);font-size:20px;line-height:1;padding:4px 0;opacity:.7}
.flow-row{display:flex;align-items:center;gap:0;width:100%}
.flow-row .flow-box{flex:1;border-radius:0}
.flow-row .flow-box:first-child{border-radius:8px 0 0 8px}
.flow-row .flow-box:last-child{border-radius:0 8px 8px 0}
.flow-row-arrow{color:var(--cyan);font-size:16px;padding:0 4px;opacity:.7}

/* === CODE === */
.code{background:#03040A;border:1px solid var(--border2);border-radius:10px;padding:16px 20px;margin:12px 0;font-family:var(--fm);font-size:12.5px;color:#8FA3BF;overflow-x:auto;line-height:1.85}
.code .kw{color:var(--violet2)}.code .fn{color:var(--cyan)}.code .str{color:var(--lime)}
.code .cm{color:var(--text3);font-style:italic}.code .num{color:var(--gold)}.code .cls{color:var(--rose)}
.code .op{color:var(--orange)}.code .hl{color:#fff;font-weight:500}

/* === CALLOUT === */
.callout{display:flex;gap:14px;padding:16px 20px;border-radius:10px;margin:16px 0;font-size:13.5px;line-height:1.75}
.c-gold{background:rgba(245,200,66,.06);border:1px solid rgba(245,200,66,.2)}
.c-cyan{background:rgba(0,229,255,.06);border:1px solid rgba(0,229,255,.2)}
.c-rose{background:rgba(255,107,138,.06);border:1px solid rgba(255,107,138,.2)}
.c-lime{background:rgba(163,230,53,.06);border:1px solid rgba(163,230,53,.2)}
.c-icon{font-size:18px;flex-shrink:0;margin-top:2px}
.c-body strong{display:block;margin-bottom:4px;font-size:13px;text-transform:uppercase;letter-spacing:1px;font-family:var(--fm)}
.c-gold .c-body strong{color:var(--gold)}.c-cyan .c-body strong{color:var(--cyan)}
.c-rose .c-body strong{color:var(--rose)}.c-lime .c-body strong{color:var(--lime)}
.c-body{color:var(--text2)}

/* === BULLET === */
.bl{list-style:none;margin:8px 0}
.bl li{display:flex;gap:10px;padding:5px 0;color:var(--text2);font-size:13.5px;line-height:1.65}
.bl li::before{content:'◆';color:var(--gold);font-size:8px;flex-shrink:0;margin-top:6px}
.bl li strong{color:#fff}
.bl.cyan li::before{color:var(--cyan)}
.bl.violet li::before{color:var(--violet)}
.bl.rose li::before{color:var(--rose)}
.bl.lime li::before{color:var(--lime)}

/* === TABLE === */
.tw{overflow-x:auto;margin-bottom:14px;border-radius:10px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--s3)}
thead th{padding:11px 16px;text-align:left;font-family:var(--fm);font-size:10px;text-transform:uppercase;letter-spacing:2px;color:var(--text3);border-bottom:1px solid var(--border);white-space:nowrap}
tbody tr{background:var(--s1);border-bottom:1px solid var(--border)}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--s2)}
tbody td{padding:10px 16px;font-size:13px;color:var(--text2);vertical-align:top}
td.hl{color:#fff;font-weight:600}
.tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-family:var(--fm);font-weight:500}
.tg{background:rgba(245,200,66,.12);color:var(--gold)}.tc{background:rgba(0,229,255,.12);color:var(--cyan)}
.tv{background:rgba(155,111,255,.12);color:var(--violet)}.tr{background:rgba(255,107,138,.12);color:var(--rose)}
.tl{background:rgba(163,230,53,.12);color:var(--lime)}.to{background:rgba(251,146,60,.12);color:var(--orange)}

/* === FORMULA === */
.formula{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:14px}
.formula-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.formula-name{font-size:15px;font-weight:700;color:#fff}
.formula-badge{font-family:var(--fm);font-size:11px;padding:3px 10px;border-radius:4px;background:rgba(245,200,66,.1);color:var(--gold)}
.formula-eq{font-family:var(--fm);font-size:13px;color:var(--cyan);background:rgba(0,229,255,.05);border:1px solid rgba(0,229,255,.15);border-radius:8px;padding:10px 16px;margin-bottom:10px}
.formula-desc{font-size:13px;color:var(--text2);margin-bottom:8px;line-height:1.7}
.formula-note{font-size:12px;color:var(--text3);border-top:1px solid var(--border);padding-top:10px;font-family:var(--fm)}

/* === TOC === */
.toc{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:28px 32px;margin-bottom:56px}
.toc h3{font-family:var(--fm);font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:3px;margin-bottom:18px}
.toc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:4px}
.toc-a{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:7px;text-decoration:none;color:var(--text2);font-size:13px;border:1px solid transparent;transition:all .2s}
.toc-a:hover{background:var(--s2);border-color:var(--border2);color:var(--gold)}
.toc-n{width:24px;height:24px;border-radius:50%;background:var(--s3);color:var(--text3);font-family:var(--fm);font-size:10px;font-weight:500;display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* === GLOSSARY === */
.gloss-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
@media(max-width:640px){.gloss-grid{grid-template-columns:1fr}}
.gloss-item{background:var(--s1);border:1px solid var(--border);border-radius:9px;padding:12px 16px}
.gloss-term{font-family:var(--fm);font-size:12px;font-weight:500;color:var(--gold);margin-bottom:4px}
.gloss-def{font-size:12.5px;color:var(--text2);line-height:1.55}

/* === QUICK REF === */
.qr{background:var(--s1);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:22px}
.qr-row{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--border)}
.qr-row:last-child{border-bottom:none}
.qr-row.qr-head{background:var(--s3)}
.qr-q{padding:11px 18px;font-size:13px;color:var(--text2);border-right:1px solid var(--border)}
.qr-a{padding:11px 18px;font-size:13px;font-weight:600;color:var(--cyan);font-family:var(--fm)}
.qr-row.qr-head .qr-q,.qr-row.qr-head .qr-a{font-size:10px;text-transform:uppercase;letter-spacing:2px;font-weight:500;font-family:var(--fm);color:var(--text3)}
.qr-a.danger{color:var(--rose)}.qr-a.warn{color:var(--gold)}

/* === COMPARE CARD === */
.compare{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.cmp-card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:18px}
.cmp-title{font-weight:700;color:#fff;font-size:14px;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.cmp-body{font-size:13px;color:var(--text2);line-height:1.7}
.pro-list,.con-list{list-style:none;margin-top:10px}
.pro-list li,.con-list li{font-size:12.5px;color:var(--text2);margin-bottom:4px;display:flex;gap:8px}
.pro-list li::before{content:'✓';color:var(--lime);font-weight:700;flex-shrink:0}
.con-list li::before{content:'✗';color:var(--rose);font-weight:700;flex-shrink:0}
@media(max-width:640px){.compare{grid-template-columns:1fr}}

/* === MILESTONE === */
.milestone{display:flex;gap:0;margin:20px 0;overflow-x:auto}
.ms-box{flex:1;min-width:120px;background:var(--s1);border:1px solid var(--border);padding:14px 10px;text-align:center;position:relative}
.ms-box:not(:last-child)::after{content:'→';position:absolute;right:-12px;top:50%;transform:translateY(-50%);color:var(--gold);font-size:16px;font-weight:700;z-index:1;background:var(--bg);padding:0 4px}
.ms-box:first-child{border-radius:9px 0 0 9px}
.ms-box:last-child{border-radius:0 9px 9px 0}
.ms-n{font-family:var(--fm);font-size:9px;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
.ms-t{font-size:12px;font-weight:700;color:#fff;margin-bottom:3px}
.ms-d{font-size:11px;color:var(--text3);line-height:1.35}

/* === ROADMAP === */
.roadmap-row{display:flex;gap:16px;padding:16px 0;border-bottom:1px solid var(--border);align-items:flex-start}
.roadmap-row:last-child{border-bottom:none}
.rm-phase{font-family:var(--fm);font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:2px;min-width:80px;padding-top:2px}
.rm-title{font-weight:700;color:#fff;font-size:14px;margin-bottom:4px}
.rm-items{font-size:13px;color:var(--text2);line-height:1.6}

/* === INTERVIEW Q === */
.iq-list{counter-reset:iq}
.iq{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:16px 20px;margin-bottom:10px;position:relative;padding-left:52px}
.iq::before{counter-increment:iq;content:counter(iq,'0'counter(iq));position:absolute;left:16px;top:50%;transform:translateY(-50%);font-family:var(--fm);font-size:13px;font-weight:500;color:var(--gold);min-width:20px}
.iq-q{font-weight:700;color:#fff;font-size:13.5px;margin-bottom:6px}
.iq-a{font-size:13px;color:var(--text2);line-height:1.7}

/* === TIMELINE === */
.timeline{position:relative;margin:20px 0}
.timeline::before{content:'';position:absolute;left:18px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--gold),var(--cyan),var(--violet))}
.tl-item{display:flex;gap:20px;padding:0 0 24px;position:relative}
.tl-dot{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;position:relative;z-index:1;border:2px solid}
.tl-dot.g{background:rgba(245,200,66,.12);border-color:var(--gold)}
.tl-dot.c{background:rgba(0,229,255,.12);border-color:var(--cyan)}
.tl-dot.v{background:rgba(155,111,255,.12);border-color:var(--violet)}
.tl-dot.r{background:rgba(255,107,138,.12);border-color:var(--rose)}
.tl-dot.l{background:rgba(163,230,53,.12);border-color:var(--lime)}
.tl-content{flex:1;padding-top:6px}
.tl-title{font-weight:700;color:#fff;font-size:14px;margin-bottom:5px}
.tl-body{font-size:13px;color:var(--text2);line-height:1.7}

/* === FOOTER === */
footer{text-align:center;padding:40px 0 20px;border-top:1px solid var(--border);margin-top:60px;color:var(--text3);font-size:12px;font-family:var(--fm)}
footer strong{color:var(--gold)}

/* === ARCHITECTURE SVG BOX === */
.arch-box{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:0;overflow:hidden;margin:16px 0}
.arch-box svg{display:block;width:100%}
</style>
</head>
