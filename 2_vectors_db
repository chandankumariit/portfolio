<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Vector Databases – Complete Beginner's Notes</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
<style>
:root{
  --bg:#0A0E1A;
  --surface:#111827;
  --surface2:#1A2233;
  --surface3:#1E2A40;
  --border:#243048;
  --border2:#2E3D5C;
  --teal:#00D4B8;
  --teal2:#00F0D0;
  --blue:#3B82F6;
  --blue2:#60A5FA;
  --purple:#A78BFA;
  --pink:#F472B6;
  --amber:#FBBF24;
  --green:#34D399;
  --red:#F87171;
  --text:#E2E8F0;
  --text2:#94A3B8;
  --text3:#64748B;
  --font-head:'Syne',sans-serif;
  --font-body:'Space Grotesk',sans-serif;
  --font-mono:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--font-body);
  background:var(--bg);
  color:var(--text);
  font-size:14px;
  line-height:1.7;
}

/* ── FLOATING DOWNLOAD BUTTON ─────────────────────────── */
.fab{
  position:fixed;bottom:28px;right:28px;z-index:9999;
  display:flex;align-items:center;gap:10px;
  background:linear-gradient(135deg,var(--teal),var(--blue));
  color:#0A0E1A;font-weight:700;font-family:var(--font-body);
  padding:14px 24px;border-radius:50px;border:none;cursor:pointer;
  font-size:14px;box-shadow:0 8px 32px rgba(0,212,184,.35);
  transition:all .3s;letter-spacing:.3px;
}
.fab:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(0,212,184,.5)}
.fab:disabled{background:#2E3D5C;color:#64748B;box-shadow:none;cursor:not-allowed;transform:none}
.fab i{font-size:16px}

/* ── PROGRESS BAR ─────────────────────────────────────── */
.progress-bar{
  position:fixed;top:0;left:0;height:3px;z-index:9998;
  background:linear-gradient(90deg,var(--teal),var(--blue),var(--purple));
  width:0%;transition:width .1s;
}

/* ── CONTAINER ─────────────────────────────────────────── */
.page{max-width:960px;margin:0 auto;padding:0 24px 80px}

/* ── HERO ──────────────────────────────────────────────── */
.hero{
  padding:70px 0 50px;text-align:center;position:relative;
  border-bottom:1px solid var(--border);margin-bottom:48px;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(0,212,184,.08),transparent 70%);
  pointer-events:none;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,212,184,.1);border:1px solid rgba(0,212,184,.25);
  color:var(--teal);padding:6px 16px;border-radius:50px;
  font-family:var(--font-mono);font-size:12px;margin-bottom:24px;
  letter-spacing:.5px;
}
.hero-tag span{width:7px;height:7px;border-radius:50%;background:var(--teal);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.hero h1{
  font-family:var(--font-head);font-size:clamp(36px,7vw,64px);
  font-weight:800;line-height:1.05;margin-bottom:18px;
  background:linear-gradient(135deg,#fff 0%,var(--teal) 50%,var(--blue) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-sub{
  font-size:16px;color:var(--text2);max-width:560px;margin:0 auto 32px;line-height:1.8;
}
.hero-chips{display:flex;flex-wrap:wrap;gap:10px;justify-content:center}
.chip{
  padding:6px 14px;border-radius:6px;font-family:var(--font-mono);font-size:12px;
  border:1px solid;cursor:default;
}
.chip-teal{background:rgba(0,212,184,.08);border-color:rgba(0,212,184,.3);color:var(--teal)}
.chip-blue{background:rgba(59,130,246,.08);border-color:rgba(59,130,246,.3);color:var(--blue2)}
.chip-purple{background:rgba(167,139,250,.08);border-color:rgba(167,139,250,.3);color:var(--purple)}
.chip-amber{background:rgba(251,191,36,.08);border-color:rgba(251,191,36,.3);color:var(--amber)}
.chip-pink{background:rgba(244,114,182,.08);border-color:rgba(244,114,182,.3);color:var(--pink)}
.chip-green{background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.3);color:var(--green)}

/* ── TOC ───────────────────────────────────────────────── */
.toc{
  background:var(--surface);border:1px solid var(--border);border-radius:16px;
  padding:28px 32px;margin-bottom:48px;
}
.toc h3{
  font-family:var(--font-head);font-size:13px;font-weight:700;
  color:var(--text3);text-transform:uppercase;letter-spacing:2px;margin-bottom:16px;
}
.toc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:6px}
.toc-link{
  display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;
  text-decoration:none;color:var(--text2);font-size:13px;
  border:1px solid transparent;transition:all .2s;
}
.toc-link:hover{background:var(--surface2);border-color:var(--border2);color:var(--teal)}
.toc-num{
  width:22px;height:22px;border-radius:50%;
  background:var(--surface3);color:var(--text3);
  font-family:var(--font-mono);font-size:11px;font-weight:700;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}

/* ── SECTION ───────────────────────────────────────────── */
.section{margin-bottom:56px}
.section-header{
  display:flex;align-items:center;gap:16px;margin-bottom:28px;
  padding-bottom:16px;border-bottom:1px solid var(--border);
}
.section-icon{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;
}
.icon-teal{background:rgba(0,212,184,.15)}
.icon-blue{background:rgba(59,130,246,.15)}
.icon-purple{background:rgba(167,139,250,.15)}
.icon-amber{background:rgba(251,191,36,.15)}
.icon-pink{background:rgba(244,114,182,.15)}
.icon-green{background:rgba(52,211,153,.15)}
.icon-red{background:rgba(248,113,113,.15)}

.section-label{
  font-family:var(--font-mono);font-size:11px;color:var(--text3);
  text-transform:uppercase;letter-spacing:2px;margin-bottom:4px;
}
.section-title{
  font-family:var(--font-head);font-size:clamp(20px,3.5vw,26px);
  font-weight:800;color:#fff;line-height:1.2;
}

/* ── CARDS ─────────────────────────────────────────────── */
.card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;padding:24px;margin-bottom:16px;
}
.card-teal{border-left:3px solid var(--teal)}
.card-blue{border-left:3px solid var(--blue)}
.card-purple{border-left:3px solid var(--purple)}
.card-amber{border-left:3px solid var(--amber)}
.card-pink{border-left:3px solid var(--pink)}
.card-green{border-left:3px solid var(--green)}
.card-red{border-left:3px solid var(--red)}

.card-title{
  font-family:var(--font-mono);font-size:12px;font-weight:700;
  text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;
}
.ct-teal{color:var(--teal)} .ct-blue{color:var(--blue2)}
.ct-purple{color:var(--purple)} .ct-amber{color:var(--amber)}
.ct-pink{color:var(--pink)} .ct-green{color:var(--green)} .ct-red{color:var(--red)}

.card p{color:var(--text2);font-size:13.5px;line-height:1.75;margin-bottom:8px}
.card p:last-child{margin-bottom:0}

/* ── GRID 2 ────────────────────────────────────────────── */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
@media(max-width:640px){.grid2,.grid3{grid-template-columns:1fr}}

/* ── COMPARISON TABLE ──────────────────────────────────── */
.table-wrap{overflow-x:auto;margin-bottom:16px;border-radius:12px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--surface3)}
thead th{
  padding:12px 16px;text-align:left;font-family:var(--font-mono);
  font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3);
  border-bottom:1px solid var(--border);white-space:nowrap;
}
tbody tr{background:var(--surface);border-bottom:1px solid var(--border)}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
tbody td{padding:11px 16px;font-size:13px;color:var(--text2);vertical-align:top}
td.hl{color:#fff;font-weight:600}
td .tag{
  display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;
  font-family:var(--font-mono);font-weight:600;
}
.tag-teal{background:rgba(0,212,184,.15);color:var(--teal)}
.tag-blue{background:rgba(59,130,246,.15);color:var(--blue2)}
.tag-purple{background:rgba(167,139,250,.15);color:var(--purple)}
.tag-amber{background:rgba(251,191,36,.15);color:var(--amber)}
.tag-red{background:rgba(248,113,113,.15);color:var(--red)}
.tag-green{background:rgba(52,211,153,.15);color:var(--green)}

/* ── CODE BLOCK ────────────────────────────────────────── */
.code-block{
  background:rgba(0,0,0,.4);border:1px solid var(--border2);
  border-radius:10px;padding:16px 20px;margin:12px 0;
  font-family:var(--font-mono);font-size:12.5px;color:#94A3B8;
  overflow-x:auto;line-height:1.8;
}
.code-block .kw{color:var(--purple)}
.code-block .str{color:var(--green)}
.code-block .fn{color:var(--blue2)}
.code-block .cm{color:var(--text3);font-style:italic}
.code-block .num{color:var(--amber)}

/* ── CALLOUT ───────────────────────────────────────────── */
.callout{
  display:flex;gap:14px;padding:16px 20px;border-radius:12px;margin:16px 0;
  font-size:13.5px;line-height:1.7;
}
.callout-warn{background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.2)}
.callout-tip{background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.2)}
.callout-info{background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.2)}
.callout-danger{background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.2)}
.callout-icon{font-size:18px;flex-shrink:0;margin-top:2px}
.callout-body strong{display:block;margin-bottom:4px;font-weight:700}
.callout-warn .callout-body strong{color:var(--amber)}
.callout-tip .callout-body strong{color:var(--green)}
.callout-info .callout-body strong{color:var(--blue2)}
.callout-danger .callout-body strong{color:var(--red)}
.callout-body{color:var(--text2)}

/* ── BULLET LIST ───────────────────────────────────────── */
.blist{list-style:none;margin:10px 0}
.blist li{
  display:flex;gap:10px;padding:5px 0;color:var(--text2);font-size:13.5px;line-height:1.65;
}
.blist li::before{
  content:'›';color:var(--teal);font-weight:700;font-size:16px;
  flex-shrink:0;margin-top:-1px;
}
.blist li strong{color:#fff}

/* ── STEP FLOW (INLINE) ────────────────────────────────── */
.step-row{display:flex;align-items:stretch;gap:0;margin:16px 0;flex-wrap:wrap}
.step-box{
  flex:1;min-width:120px;background:var(--surface);border:1px solid var(--border);
  padding:14px;text-align:center;position:relative;
}
.step-box:not(:last-child)::after{
  content:'→';position:absolute;right:-14px;top:50%;transform:translateY(-50%);
  color:var(--teal);font-size:16px;font-weight:700;z-index:1;
  background:var(--bg);padding:0 4px;
}
.step-box:first-child{border-radius:10px 0 0 10px}
.step-box:last-child{border-radius:0 10px 10px 0}
.step-n{
  font-family:var(--font-mono);font-size:10px;color:var(--teal);
  font-weight:700;margin-bottom:6px;letter-spacing:1px;
}
.step-t{font-size:12px;font-weight:700;color:#fff;margin-bottom:4px}
.step-d{font-size:11px;color:var(--text3);line-height:1.4}

/* ── METRIC FORMULA ────────────────────────────────────── */
.formula-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:12px;padding:20px;margin-bottom:14px;
}
.formula-header{
  display:flex;justify-content:space-between;align-items:flex-start;
  margin-bottom:12px;flex-wrap:wrap;gap:8px;
}
.formula-name{font-size:15px;font-weight:700;color:#fff}
.formula-badge{
  font-family:var(--font-mono);font-size:11px;padding:3px 10px;
  border-radius:4px;background:rgba(0,212,184,.15);color:var(--teal);
}
.formula-eq{
  font-family:var(--font-mono);font-size:13px;color:var(--teal);
  background:rgba(0,212,184,.06);border:1px solid rgba(0,212,184,.15);
  border-radius:8px;padding:10px 16px;margin-bottom:12px;
}
.formula-desc{font-size:13px;color:var(--text2);margin-bottom:10px}
.formula-when{
  font-size:12px;color:var(--text3);border-top:1px solid var(--border);
  padding-top:10px;display:flex;gap:8px;align-items:flex-start;
}
.formula-when strong{color:var(--amber);flex-shrink:0}

/* ── INDEX CARD ────────────────────────────────────────── */
.idx-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;padding:22px;margin-bottom:14px;
}
.idx-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.idx-name{font-size:15px;font-weight:700;color:#fff}
.idx-big-o{font-family:var(--font-mono);font-size:12px;padding:3px 10px;border-radius:4px}
.idx-body{color:var(--text2);font-size:13px;margin-bottom:12px;line-height:1.7}
.idx-cols{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
.idx-pro h5,.idx-con h5{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.idx-pro h5{color:var(--green)} .idx-con h5{color:var(--red)}
.idx-pro li,.idx-con li{font-size:12.5px;margin-bottom:4px;color:var(--text2)}
.idx-pro li::before{content:'+ ';color:var(--green);font-weight:700}
.idx-con li::before{content:'− ';color:var(--red);font-weight:700}

/* ── PITFALL CARD ──────────────────────────────────────── */
.pitfall{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;overflow:hidden;margin-bottom:16px;
}
.pitfall-top{padding:18px 22px;background:rgba(248,113,113,.06);border-bottom:1px solid rgba(248,113,113,.15)}
.pitfall-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.pitfall-desc{font-size:13px;color:var(--text2);line-height:1.7}
.pitfall-bottom{padding:18px 22px;background:rgba(52,211,153,.04);border-top:1px solid rgba(52,211,153,.12)}
.pitfall-fix{font-size:12px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.pitfall-fix-text{font-size:13px;color:var(--text2);line-height:1.7}

/* ── DB GRID ───────────────────────────────────────────── */
.db-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:16px}
.db-card{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:18px;transition:all .2s;
}
.db-card:hover{border-color:var(--teal);background:var(--surface2)}
.db-name{font-family:var(--font-mono);font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.db-type{font-size:11px;color:var(--text3);margin-bottom:10px}
.db-desc{font-size:12.5px;color:var(--text2);line-height:1.6;margin-bottom:10px}
.db-best{
  font-size:11px;padding:4px 10px;border-radius:6px;
  background:rgba(0,212,184,.08);border:1px solid rgba(0,212,184,.2);color:var(--teal);
  display:inline-block;font-family:var(--font-mono);
}

/* ── QUICK REF TABLE ───────────────────────────────────── */
.qr-table{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;overflow:hidden;margin-bottom:24px;
}
.qr-row{
  display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--border);
}
.qr-row:last-child{border-bottom:none}
.qr-row.header{background:var(--surface3)}
.qr-q{padding:12px 20px;font-size:13px;color:var(--text2);border-right:1px solid var(--border)}
.qr-a{padding:12px 20px;font-size:13px;font-weight:600;color:var(--teal);font-family:var(--font-mono)}
.qr-row.header .qr-q,.qr-row.header .qr-a{color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:1.5px;font-weight:700}
.qr-a.danger{color:var(--red)}
.qr-a.warn{color:var(--amber)}

/* ── GLOSSARY ──────────────────────────────────────────── */
.glossary{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
@media(max-width:640px){.glossary{grid-template-columns:1fr}}
.gloss-item{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:12px 16px;
}
.gloss-term{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--teal);margin-bottom:4px}
.gloss-def{font-size:12.5px;color:var(--text2);line-height:1.55}

/* ── FLOW DIAGRAM ──────────────────────────────────────── */
#flow-diagram-svg{width:100%;max-width:900px;display:block;margin:0 auto}

/* ── FOOTER ────────────────────────────────────────────── */
.footer{
  text-align:center;padding:32px 0 20px;
  border-top:1px solid var(--border);margin-top:48px;
  color:var(--text3);font-size:12px;
}
.footer strong{color:var(--teal)}

/* ── PRINT ─────────────────────────────────────────────── */
@media print{
  .fab,.progress-bar{display:none}
  body{background:#fff;color:#000}
}
</style>
</head>
